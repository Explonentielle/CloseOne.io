generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String       @id @default(cuid())
  clerkId     String       @unique
  email       String       @unique
  firstName   String?
  lastName    String?
  avatarUrl   String?
  role        Role         @default(CLOSER)
  ecosystemId String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deals       Deal[]
  objectives  Objective[]
  ecosystem   Ecosystem?   @relation(fields: [ecosystemId], references: [id])
  metrics     UserMetrics?
}

model Deal {
  id          String     @id @default(cuid())
  name        String
  amount      Float
  commission  Float
  status      DealStatus
  userId      String
  ecosystemId String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  ecosystem   Ecosystem? @relation(fields: [ecosystemId], references: [id])
  user        User       @relation(fields: [userId], references: [id])
}

model Ecosystem {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deals       Deal[]
  users       User[]
}

model UserMetrics {
  id             String   @id @default(cuid())
  userId         String   @unique
  monthlyRevenue Float    @default(0)
  totalRevenue   Float    @default(0)
  winRate        Float?
  totalDeals     Int      @default(0)
  wonDeals       Int      @default(0)
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])
}

model Objective {
  id           String        @id @default(cuid())
  userId       String
  title        String
  description  String?
  targetValue  Float
  currentValue Float         @default(0)
  type         ObjectiveType
  periodStart  DateTime?
  periodEnd    DateTime?
  isCompleted  Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id])
}

enum Role {
  USER
  CLOSER
  MANAGER
  ADMIN
}

enum DealStatus {
  PENDING
  WON
  LOST
}

enum ObjectiveType {
  REVENUE
  DEALS_COUNT
  WIN_RATE
  CUSTOM
}
